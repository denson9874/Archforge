{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ArchWeaver",
  "version": "1.0.0",
  "identifier": "com.archweaver.app",
  "mainBinaryName": "ArchWeaver",
  "build": {
    "beforeBuildCommand": "npm run build:web",
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "ArchWeaver",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
