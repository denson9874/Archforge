rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) 
          && data.keys().size() == 3
          && data.uid is string && data.uid.size() >= 1 && data.uid.size() <= 128
          && data.email is string && data.email.size() >= 3 && data.email.size() <= 256
          && data.createdAt is timestamp
          && data.uid == request.auth.uid;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // No list on users
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if false; // Immutable
      allow delete: if false;
    }
  }
}
